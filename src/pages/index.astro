---
import BaseLayout from "../layouts/BaseLayout.astro";
const locations = ["Kayuringin Bekasi","Pondok Ungu Bekasi","Pedurungan Semarang","Legenda Wisata Cibubur","Grand Wisata Bekasi","Bandar Lampung"];
const products = [
  ["Dori Fillet Frozen","/wp-content/uploads/2024/07/Dori-Fillet-Non-Blood-Line.webp"],
  ["Lele Fillet Frozen","/wp-content/uploads/2024/07/Lele-Fillet-1.webp"],
  ["Cumi Frozen","/wp-content/uploads/2024/07/Cumi-1.webp"],
  ["Gurame Fillet Frozen","/wp-content/uploads/2024/07/Gurame-Fillet-1.webp"],
  ["Tuna Fillet Frozen","/wp-content/uploads/2024/08/Tuna-Fillet.webp"],
  ["Tenggiri Fillet Frozen","/wp-content/uploads/2024/08/Tenggiri-Fillet.webp"],
  ["Udang Beku","/wp-content/uploads/2025/10/ChatGPT-Image-Oct-17-2025-11_16_56-PM.png"],
  ["Seafood & Daging Frozen","/wp-content/uploads/2025/10/ChatGPT-Image-Oct-12-2025-12_23_31-PM.png"]
];
const posts = Object.values(import.meta.glob("../content/blog/*.md", { eager: true })).slice(0, 6);
---
<BaseLayout>
  <section class="hero"><div class="hero-media"><img src="/wp-content/uploads/2025/10/ChatGPT-Image-Oct-12-2025-12_04_31-PM.png" alt="Toko daging dan ikan Meat & Fish" /></div><div class="container hero-grid"><div><span class="eyebrow">Frozen food berkualitas</span><h1>Segar, praktis, siap untuk setiap dapur.</h1><p>Daging, ayam, ikan, dan seafood beku untuk keluarga, restoran, reseller, dan mitra usaha.</p><a class="button" href="/produk-meatfish/">Lihat Produk</a></div><div class="hero-card"><strong>Belanja & kemitraan</strong><h2>Pasokan stabil untuk kebutuhan Anda</h2><p>Konsultasikan produk, supplier, atau peluang kemitraan bersama tim Meat & Fish.</p><a class="button secondary" href="/gabung-kemitraan/">Gabung Kemitraan</a></div></div></section>
  <section class="section"><div class="container"><h2 class="section-title">Lokasi Toko Meat & Fish</h2><p class="lead">Temukan toko terdekat dan hubungi tim kami untuk ketersediaan produk.</p><div class="grid">{locations.map((x,i)=><article class="card"><div class="card-body"><span class="pill">{i<4?"Tersedia":"Segera dibuka"}</span><h3>{x}</h3>{i<4&&<a href="https://wa.me/6280000000000">Hubungi WhatsApp →</a>}</div></article>)}</div></div></section>
  <section class="section alt"><div class="container"><span class="eyebrow dark">Pilihan terbaik Meat & Fish</span><h2 class="section-title">Produk Frozen Favorit</h2><div class="grid four">{products.map(([name,image])=><article class="card product-card"><img src={image} alt={name} loading="lazy"/><div class="card-body"><h3>{name}</h3><a class="button" href="/produk-meatfish/">Lihat Produk</a></div></article>)}</div></div></section>
  <section class="section alt"><div class="container"><div class="cta"><h2>Download Katalog Produk Meat & Fish</h2><p>Katalog sedang diperbarui. Hubungi tim kami untuk daftar produk dan harga terbaru.</p><a class="button" href="https://wa.me/6280000000000">Minta Katalog</a></div></div></section>
  <section class="section"><div class="container"><h2 class="section-title">Artikel terbaru</h2><div class="grid">{posts.map((post:any)=><article class="card"><img src={post.frontmatter.image||"/images/article-placeholder.svg"} alt={post.frontmatter.title} loading="lazy"/><div class="card-body"><span class="pill">{post.frontmatter.categories?.[0]||"Frozen"}</span><h3><a href={`/${post.frontmatter.slug}/`}>{post.frontmatter.title}</a></h3><p>{post.frontmatter.description}</p></div></article>)}</div></div></section>
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
const locations = ["Kayuringin Bekasi","Pondok Ungu Bekasi","Pedurungan Semarang","Legenda Wisata Cibubur","Grand Wisata Bekasi","Bandar Lampung"];
const meat = ["Beef Slice Frozen","Beef Steak Sirloin Frozen","Beef Tenderloin Frozen","Daging Rendang Frozen","Beef Short Ribeye Frozen","Beef Shortplate Frozen","Beef Oxtail Frozen","Sirloin Meltique Frozen"];
const fish = ["Ikan Dori Fillet","Ikan Lele Fillet","Ikan Salmon Fillet","Cumi Beku","Udang Beku","Ikan Tuna Fillet","Ikan Gurame Fillet","Ikan Tenggiri Fillet"];
const posts = Object.values(import.meta.glob("../content/blog/*.md", { eager: true })).slice(0, 6);
---
<BaseLayout>
  <section class="hero"><div class="container hero-grid"><div><span class="eyebrow">Frozen food berkualitas</span><h1>Segar, praktis, siap untuk setiap dapur.</h1><p>Daging, ayam, ikan, dan seafood beku untuk keluarga, restoran, reseller, dan mitra usaha.</p><a class="button" href="/produk-meatfish/">Lihat Produk</a></div><div class="hero-card"><strong>Belanja & kemitraan</strong><h2>Pasokan stabil untuk kebutuhan Anda</h2><p>Konsultasikan produk, supplier, atau peluang kemitraan bersama tim Meat & Fish.</p><a class="button secondary" href="/gabung-kemitraan/">Gabung Kemitraan</a></div></div></section>
  <section class="section"><div class="container"><h2 class="section-title">Lokasi Toko Meat & Fish</h2><p class="lead">Temukan toko terdekat dan hubungi tim kami untuk ketersediaan produk.</p><div class="grid">{locations.map((x,i)=><article class="card"><div class="card-body"><span class="pill">{i<4?"Tersedia":"Segera dibuka"}</span><h3>{x}</h3>{i<4&&<a href="https://wa.me/6280000000000">Hubungi WhatsApp →</a>}</div></article>)}</div></div></section>
  <section class="section alt"><div class="container"><h2 class="section-title">Daging Frozen</h2><div class="grid four">{meat.map(x=><article class="card"><img src="/images/article-placeholder.svg" alt={x} loading="lazy"/><div class="card-body"><h3>{x}</h3><a class="button" href="https://wa.me/6280000000000">Order</a></div></article>)}</div></div></section>
  <section class="section"><div class="container"><h2 class="section-title">Ikan & Seafood Frozen</h2><div class="grid four">{fish.map(x=><article class="card"><img src="/images/article-placeholder.svg" alt={x} loading="lazy"/><div class="card-body"><h3>{x}</h3><a href="/produk-meatfish/">Lihat produk →</a></div></article>)}</div></div></section>
  <section class="section alt"><div class="container"><div class="cta"><h2>Download Katalog Produk Meat & Fish</h2><p>Katalog sedang diperbarui. Hubungi tim kami untuk daftar produk dan harga terbaru.</p><a class="button" href="https://wa.me/6280000000000">Minta Katalog</a></div></div></section>
  <section class="section"><div class="container"><h2 class="section-title">Artikel terbaru</h2><div class="grid">{posts.map((post:any)=><article class="card"><img src={post.frontmatter.image||"/images/article-placeholder.svg"} alt={post.frontmatter.title} loading="lazy"/><div class="card-body"><span class="pill">{post.frontmatter.categories?.[0]||"Frozen"}</span><h3><a href={`/${post.frontmatter.slug}/`}>{post.frontmatter.title}</a></h3><p>{post.frontmatter.description}</p></div></article>)}</div></div></section>
</BaseLayout>

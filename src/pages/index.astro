---
import BaseLayout from "../layouts/BaseLayout.astro";
import LocationCards from "../components/LocationCards.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
const products = [
  ["Dori Fillet Frozen","/wp-content/uploads/2024/07/Dori-Fillet-Non-Blood-Line.webp"],
  ["Lele Fillet Frozen","/wp-content/uploads/2024/07/Lele-Fillet-1.webp"],
  ["Cumi Frozen","/wp-content/uploads/2024/07/Cumi-1.webp"],
  ["Gurame Fillet Frozen","/wp-content/uploads/2024/07/Gurame-Fillet-1.webp"],
  ["Tuna Fillet Frozen","/wp-content/uploads/2024/08/Tuna-Fillet.webp"],
  ["Tenggiri Fillet Frozen","/wp-content/uploads/2024/08/Tenggiri-Fillet.webp"],
  ["Udang Beku","/wp-content/uploads/2025/10/ChatGPT-Image-Oct-17-2025-11_16_56-PM.png"],
  ["Seafood & Daging Frozen","/wp-content/uploads/2025/10/ChatGPT-Image-Oct-12-2025-12_23_31-PM.png"]
];
const posts = Object.values(import.meta.glob("../content/blog/*.md", { eager: true })).slice(0, 6);
---
<BaseLayout>
  <section class="home-hero"><div class="container home-hero-grid"><div class="home-hero-copy"><span class="eyebrow dark">Meat & Fish Frozen Food</span><h1>Daging dan seafood berkualitas untuk kebutuhan Anda</h1><p>Belanja daging, ayam, ikan, seafood, dan frozen food dengan pilihan lengkap untuk keluarga maupun bisnis.</p><div class="hero-actions"><WhatsAppButton label="Belanja via WhatsApp" /><a class="text-link" href="/produk-meatfish/">Lihat semua produk →</a></div><div class="hero-features"><span>✓ Produk berkualitas</span><span>✓ Pilihan lengkap</span><span>✓ Banyak lokasi</span></div></div><div class="home-hero-image"><img src="/wp-content/uploads/2025/10/ChatGPT-Image-Oct-12-2025-12_23_31-PM.png" alt="Pilihan produk daging dan seafood Meat & Fish" /></div></div></section>
  <section class="category-strip"><div class="container category-list"><a href="/produk-meatfish/">Daging Frozen</a><a href="/produk-meatfish/">Ayam Frozen</a><a href="/produk-meatfish/">Ikan Fillet</a><a href="/produk-meatfish/">Seafood</a><a href="/gabung-kemitraan/">Kemitraan</a></div></section>
  <section class="section alt"><div class="container"><span class="eyebrow dark">Pilihan terbaik Meat & Fish</span><h2 class="section-title">Produk Frozen Favorit</h2><div class="grid four">{products.map(([name,image])=><article class="card product-card"><img src={image} alt={name} loading="lazy"/><div class="card-body"><h3>{name}</h3><WhatsAppButton label="Pesan via WhatsApp" /></div></article>)}</div></div></section>
  <section class="section"><div class="container"><span class="eyebrow dark">Kunjungi toko kami</span><h2 class="section-title">Lokasi Toko Meat & Fish</h2><p class="lead">Pilih toko terdekat, buka petunjuk Google Maps, atau tanyakan stok melalui WhatsApp.</p><LocationCards /></div></section>
  <section class="section alt"><div class="container"><div class="cta cta-split"><div><span class="eyebrow dark">Butuh bantuan?</span><h2>Temukan produk yang sesuai kebutuhan Anda</h2><p>Hubungi tim Meat & Fish untuk informasi produk, harga, supplier, dan kemitraan.</p></div><WhatsAppButton label="Chat dengan tim kami" /></div></div></section>
  <section class="section"><div class="container"><h2 class="section-title">Artikel terbaru</h2><div class="grid">{posts.map((post:any)=><article class="card"><img src={post.frontmatter.image||"/images/article-placeholder.svg"} alt={post.frontmatter.title} loading="lazy"/><div class="card-body"><span class="pill">{post.frontmatter.categories?.[0]||"Frozen"}</span><h3><a href={`/${post.frontmatter.slug}/`}>{post.frontmatter.title}</a></h3><p>{post.frontmatter.description}</p></div></article>)}</div></div></section>
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import LocationCards from "../components/LocationCards.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";

const productSections = [
  {
    title: "Daging Frozen",
    items: [
      ["Beef Slice Frozen", "https://meatfish.id/wp-content/uploads/2024/07/Beef-Slice-Low-Fat-1.webp"],
      ["Beef Steak Sirloin Frozen", "https://meatfish.id/wp-content/uploads/2024/07/Steak-Sirloin-1.webp"],
      ["Beef Steak Tenderloin Frozen", "https://meatfish.id/wp-content/uploads/2024/07/Steak-Tenderloin-2.webp"],
      ["Daging Rendang Frozen", "https://meatfish.id/wp-content/uploads/2024/07/Daging-Rendang-3.webp"],
      ["Beef Short Ribeye Frozen", "https://meatfish.id/wp-content/uploads/2024/07/Short-Ribeye-2.webp"],
      ["Beef Shortplate Frozen", "https://meatfish.id/wp-content/uploads/2024/07/Shortplate-1.webp"],
      ["Beef Oxtail Frozen", "https://meatfish.id/wp-content/uploads/2024/07/Oxtail-Import-2.webp"],
      ["Beef Sirloin Meltique Frozen", "https://meatfish.id/wp-content/uploads/2024/07/Sirloin-Meltique-2.webp"],
      ["Daging Frozen lainnya", "https://meatfish.id/wp-content/uploads/2024/07/WhatsApp-Image-2025-12-22-at-17.35.31-1.webp"]
    ]
  },
  {
    title: "Ikan Frozen",
    items: [
      ["Ikan Dori Fillet Beku", "https://meatfish.id/wp-content/uploads/2024/07/Dori-Fillet-2.webp"],
      ["Ikan Lele Fillet Beku", "https://meatfish.id/wp-content/uploads/2024/07/Lele-Fillet-3.webp"],
      ["Ikan Salmon Fillet Beku", "https://meatfish.id/wp-content/uploads/2024/07/Salmon-Portion-1-1.webp"],
      ["Cumi Beku", "https://meatfish.id/wp-content/uploads/2024/07/Cumi-Ring-2.webp"],
      ["Udang Beku", "https://meatfish.id/wp-content/uploads/2024/07/Udang-CPND-2.webp"],
      ["Ikan Tuna Fillet Beku", "https://meatfish.id/wp-content/uploads/2024/07/Tuna-Steak-3.webp"],
      ["Ikan Gurame Fillet Beku", "https://meatfish.id/wp-content/uploads/2024/07/Gurame-1.webp"],
      ["Ikan Tenggiri Fillet Beku", "https://meatfish.id/wp-content/uploads/2024/07/Tenggiri-Steak-3-1.webp"],
      ["Ikan Salem Beku", "https://meatfish.id/wp-content/uploads/2024/07/Salem-1.webp"],
      ["Ikan Nila Fillet Beku", "https://meatfish.id/wp-content/uploads/2024/07/Tilapia-2.png"],
      ["Ikan Cucut Fillet Beku", "https://meatfish.id/wp-content/uploads/2024/07/Cucut-Fillet-2.webp"],
      ["Ikan Kakap Merah Fillet Beku", "https://meatfish.id/wp-content/uploads/2024/07/Kakap-Merah-Fillet-3.webp"],
      ["Ikan Kembung Beku", "https://meatfish.id/wp-content/uploads/2024/07/Kembung-Banjar-2.webp"],
      ["Ikan Shisamo Beku", "https://meatfish.id/wp-content/uploads/2024/07/Shisamo-1.webp"],
      ["Ikan Cakalang Beku", "https://meatfish.id/wp-content/uploads/2024/07/Cakalang-1.webp"],
      ["Ikan Bandeng Beku", "https://meatfish.id/wp-content/uploads/2024/07/Bandeng-2.webp"]
    ]
  }
];

const supplierCards = [
  {
    title: "Bumbu Masak",
    description: "Pasokan bumbu dapur, saus, dan kebutuhan pendukung untuk toko maupun resto.",
    image: "https://meatfish.id/wp-content/uploads/2024/08/DALL%C2%B7E-2024-08-29-21.06.58-A-beautifully-plated-dish-featuring-a-grilled-frozen-salmon-fillet-surrounded-by-roasted-vegetables-such-as-zucchini-red-bell-peppers-and-onions.-Th.webp"
  },
  {
    title: "Makanan Olahan Frozen",
    description: "Produk olahan frozen food untuk kebutuhan harian dan bisnis kuliner.",
    image: "https://meatfish.id/wp-content/uploads/2024/09/DALL%C2%B7E-2024-09-03-21.52.51-A-beautifully-presented-dish-of-grilled-salmon-on-a-white-plate.-The-salmon-is-perfectly-cooked-with-a-golden-brown-crust-on-top-garnished-with-fresh.webp"
  },
  {
    title: "Daging / Ikan / Ayam Frozen",
    description: "Kategori utama Meat & Fish untuk rumah tangga, reseller, dan mitra bisnis.",
    image: "https://meatfish.id/wp-content/uploads/2024/09/DALL%C2%B7E-2024-09-03-22.01.52-A-kitchen-scene-with-a-focus-on-cooking-frozen-seafood.-A-chef-is-preparing-a-dish-using-various-frozen-seafood-items-like-shrimp-calamari-and-mixed.webp"
  }
];

const latestPosts = Object.values(import.meta.glob("../content/blog/*.md", { eager: true }))
  .map((post: any) => post.frontmatter)
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 8);

const featuredPosts = latestPosts.slice(0, 4);
const categories = [
  "Ayam",
  "Daging",
  "Frozen Food",
  "Ikan",
  "Seafood",
  "Resep",
  "Supplier",
  "Franchise"
];
---
<BaseLayout>
  <section class="reference-hero">
    <div class="container reference-hero-grid">
      <div class="reference-hero-copy">
        <span class="reference-kicker">Pusat Toko Daging &amp; Ikan Frozen Indonesia</span>
        <h1>Daging, ikan, seafood, dan frozen food berkualitas untuk keluarga dan bisnis.</h1>
        <p>Semua dibuat mengikuti tampilan utama referensi: hero besar, lokasi toko, katalog produk, supplier, dan artikel terbaru dalam satu alur yang jelas.</p>
        <div class="reference-actions">
          <WhatsAppButton label="Hubungi WhatsApp" />
          <a class="reference-link" href="/produk-meatfish/">Lihat produk</a>
        </div>
        <div class="reference-badges">
          <span>Produk berkualitas</span>
          <span>Lokasi banyak</span>
          <span>Siap order</span>
        </div>
      </div>
    </div>
  </section>

  <section class="reference-locations section-tight">
    <div class="container">
      <div class="reference-section-head">
        <h2>Lokasi Toko</h2>
        <p>Pilih toko terdekat dan buka petunjuk arah atau WhatsApp.</p>
      </div>
      <LocationCards />
    </div>
  </section>

  <section class="reference-products">
    <div class="container">
      <div class="reference-section-head">
        <h2>Produk Meat &amp; Fish</h2>
        <p>Katalog disusun dengan urutan dan gambar yang sama seperti referensi.</p>
      </div>
      {productSections.map((section) => (
        <div class="reference-product-group">
          <h3>{section.title}</h3>
          <div class="grid reference-grid">
            {section.items.map(([name, image]) => (
              <article class="card reference-card">
                <img src={image} alt={name} loading="lazy" />
                <div class="card-body">
                  <h4>{name}</h4>
                  <WhatsAppButton label="Order" />
                </div>
              </article>
            ))}
          </div>
        </div>
      ))}
      <div class="reference-download">
        <h3>DOWNLOAD PDF KATALOG PRODUK Meat &amp; Fish</h3>
        <a class="button secondary" href="https://drive.google.com/file/d/1v7RIv-XQXVv6rr2fq5mZRWBkSI1CmzKJ/view?usp=sharing" target="_blank" rel="noopener noreferrer">KLIK DISINI DOWNLOAD PDF</a>
      </div>
    </div>
  </section>

  <section class="reference-supplier section-tight">
    <div class="container">
      <div class="reference-section-head">
        <h2>Jadi Supplier</h2>
        <p>Tiga kategori utama yang paling dekat dengan tampilan referensi halaman depan.</p>
      </div>
      <div class="grid reference-supplier-grid">
        {supplierCards.map((item) => (
          <article class="card reference-supplier-card">
            <img src={item.image} alt={item.title} loading="lazy" />
            <div class="card-body">
              <h3>{item.title}</h3>
              <p>{item.description}</p>
              <WhatsAppButton label="Tanya Supplier" />
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="reference-feature-banner">
    <div class="container feature-banner-inner">
      <div>
        <span class="reference-kicker light">Meat &amp; Fish</span>
        <h2>Pusat Toko Daging &amp; Ikan Frozen Indonesia</h2>
        <p>Disusun untuk terasa lebih dekat ke homepage contoh: kuat pada visual produk, lokasi, dan jalur kontak.</p>
      </div>
      <WhatsAppButton label="Chat sekarang" />
    </div>
  </section>

  <section class="reference-articles section-tight">
    <div class="container">
      <div class="reference-section-head">
        <h2>Berita &amp; Artikel Terbaru</h2>
        <p>Artikel terkini tetap ditampilkan agar homepage terasa hidup seperti referensi.</p>
      </div>
      <div class="grid reference-article-grid">
        {featuredPosts.map((post: any) => (
          <article class="card reference-article-card">
            <img src={post.image || "/images/article-placeholder.svg"} alt={post.title} loading="lazy" />
            <div class="card-body">
              <span class="pill">{post.categories?.[0] || "Artikel"}</span>
              <h3><a href={`/${post.slug}/`}>{post.title}</a></h3>
              <p>{post.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="reference-trending section-tight">
    <div class="container">
      <div class="reference-section-head">
        <h2>Trending</h2>
        <p>Daftar kategori dan artikel tambahan untuk mempertahankan kepadatan konten seperti referensi.</p>
      </div>
      <div class="reference-tags">
        {categories.map((category) => <a href={`/category/${category.toLowerCase().replace(/\s+/g, "-")}/`}>{category}</a>)}
      </div>
      <div class="grid reference-article-grid">
        {latestPosts.map((post: any) => (
          <article class="card reference-article-card small">
            <img src={post.image || "/images/article-placeholder.svg"} alt={post.title} loading="lazy" />
            <div class="card-body">
              <h3><a href={`/${post.slug}/`}>{post.title}</a></h3>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

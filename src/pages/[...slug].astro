---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import routes from "../data/routes.json";
import routeMedia from "../data/route-media.json";

const required = ["produk-meatfish","daftar-supplier-meatfish","gabung-kemitraan","trend-daging-ikan-frozen","tentang-meatfish","lokasi-meat-fish"];
const modules:any[] = Object.values(import.meta.glob("../content/blog/*.md", { eager: true }));
const posts = modules.map((m:any)=>({frontmatter:m.frontmatter, Content:m.Content}));
export function getStaticPaths() {
  const requiredPaths = ["produk-meatfish","daftar-supplier-meatfish","gabung-kemitraan","trend-daging-ikan-frozen","tentang-meatfish","lokasi-meat-fish"];
  const articlePaths = posts.map((post:any)=>`/${post.frontmatter.slug}/`);
  const routePaths = [...new Set([...routes.map((r:any)=>r.path), ...requiredPaths.map(x=>`/${x}/`), ...articlePaths])].filter(x=>x!=="/");
  return routePaths.map((path:string)=>({params:{slug:path.replace(/^\/|\/$/g,"")},props:{path}}));
}
const { path } = Astro.props;
const clean = path.replace(/^\/|\/$/g,"");
const parts = clean.split("/");
const kind = parts[0];
const slug = parts.at(-1);
const post:any = posts.find((p:any)=>p.frontmatter.slug===slug);
const pretty = (value:string) => value.replace(/-/g," ").replace(/\b\w/g,c=>c.toUpperCase());
const title = post?.frontmatter.title || pretty(slug);
const description = post?.frontmatter.description || `Informasi ${title} dari Meat & Fish, penyedia daging, ikan, seafood, dan frozen food berkualitas.`;
const pageImage = (routeMedia as Record<string,string>)[path] || "/wp-content/uploads/2025/10/ChatGPT-Image-Oct-12-2025-12_23_31-PM.png";
const isArchive = kind==="tag" || kind==="category";
const staticType = required.includes(clean) ? clean : null;
const categoryPosts = isArchive ? posts.filter((p:any)=>{
  const vals = kind==="category" ? p.frontmatter.categories||[] : p.frontmatter.tags||[];
  return vals.some((v:string)=>v.toLowerCase().replace(/\s+/g,"-")===slug);
}) : [];
const articleLd = post ? {"@context":"https://schema.org","@type":"Article",headline:title,datePublished:post.frontmatter.date,author:{"@type":"Person","name":post.frontmatter.author||"administrator"},image:new URL(post.frontmatter.image||"/images/article-placeholder.svg",Astro.site).href} : null;
---
<BaseLayout title={`${title} | Meat & Fish`} description={description} image={post?.frontmatter.image || pageImage} type={post?"article":"website"}>
  <Breadcrumbs items={isArchive?[{name:pretty(kind),url:`/${kind}/`},{name:title,url:path}]:[{name:title,url:path}]} />
  {articleLd && <script type="application/ld+json" set:html={JSON.stringify(articleLd)} />}
  {post ? <><header class="page-head container"><span class="pill">{post.frontmatter.categories?.[0]||"Artikel"}</span><h1>{title}</h1><p class="article-meta">Published {new Date(post.frontmatter.date).toLocaleDateString("id-ID")} · By {post.frontmatter.author||"administrator"}</p></header><div class="container article-layout"><article class="article-content"><img src={post.frontmatter.image||"/images/article-placeholder.svg"} alt={title}/><post.Content /></article><aside class="sidebar"><h2>Terbaru</h2>{posts.slice(0,8).map((p:any)=><a href={`/${p.frontmatter.slug}/`}>{p.frontmatter.title}</a>)}<h2>Categories</h2>{["Ayam","Daging","Franchise","Frozen","Ikan","Resep masakan","Tips"].map(c=><a href={`/category/${c.toLowerCase().replace(" ","-")}/`}>{c}</a>)}</aside></div></>
  : isArchive ? <section class="section"><div class="container"><header class="page-head archive-head"><div><span class="eyebrow">{pretty(kind)}</span><h1>{title}</h1></div><img src={pageImage} alt={title} /></header>{categoryPosts.length?<div class="grid">{categoryPosts.map((p:any)=><article class="card"><img src={p.frontmatter.image||pageImage} alt={p.frontmatter.title} loading="lazy"/><div class="card-body"><h3><a href={`/${p.frontmatter.slug}/`}>{p.frontmatter.title}</a></h3><p>{p.frontmatter.description}</p></div></article>)}</div>:<p class="empty-note">Arsip ini sudah memiliki URL aktif. Artikel terkait akan ditampilkan saat konten dengan label ini diterbitkan.</p>}</div></section>
  : staticType==="produk-meatfish" ? <section class="section"><div class="container"><header class="page-head"><h1>Produk Meat & Fish</h1><p class="lead">Pilihan daging, ayam, ikan, dan seafood frozen untuk rumah tangga maupun bisnis.</p></header>{["Daging Frozen","Ayam Frozen","Ikan & Seafood Frozen"].map(group=><><h2>{group}</h2><div class="grid">{["Paket Ekonomis","Pilihan Keluarga","Paket Bisnis"].map(x=><article class="card"><img src={(routeMedia as Record<string,string>)[`/${group.toLowerCase().replaceAll(" ","-")}/`]||pageImage} alt={`${group} ${x}`}/><div class="card-body"><h3>{group} – {x}</h3><a class="button" href="https://wa.me/6280000000000">Order</a></div></article>)}</div></>)}</div></section>
  : staticType==="gabung-kemitraan" ? <section class="section"><div class="container"><header class="page-head"><h1>Gabung Kemitraan Meat & Fish</h1><p class="lead">Bisnis toko daging dan frozen food dengan dukungan supply chain dan digitalisasi.</p></header><div class="grid">{["Tentang Kemitraan","Visi & Misi","Konsep Kemitraan","Dukungan Digitalisasi","Dukungan Supply Chain","Proyeksi BEP"].map(x=><article class="card"><div class="card-body"><h2>{x}</h2><p>Program disiapkan untuk membantu mitra menjalankan toko secara terstruktur, efisien, dan berkelanjutan.</p></div></article>)}</div><div class="cta"><h2>Paket Minimarket, Medium, dan Premium</h2><p>Konsultasikan lokasi, modal, dan paket yang sesuai dengan tim kemitraan.</p><a class="button" href="https://wa.me/6280000000000">Klik untuk Gabung Kemitraan</a></div></div></section>
  : staticType==="daftar-supplier-meatfish" ? <section class="section"><div class="container"><header class="page-head"><h1>Daftar Jadi Supplier Meat & Fish</h1></header><div class="grid">{["Bumbu Masak","Makanan Olahan Frozen","Daging / Ikan / Ayam Frozen"].map(x=><article class="card"><div class="card-body"><h2>{x}</h2><p>Ajukan produk, legalitas, kapasitas pasokan, dan area distribusi Anda.</p><a class="button" href="https://wa.me/6280000000000">Daftar</a></div></article>)}</div></div></section>
  : staticType==="lokasi-meat-fish" ? <section class="section"><div class="container"><header class="page-head"><h1>Lokasi Toko Meat & Fish</h1></header><div class="grid">{["Kayuringin Bekasi","Pondok Ungu Bekasi","Pedurungan Semarang","Legenda Wisata Cibubur","Grand Wisata Bekasi","Bandar Lampung"].map(x=><article class="card"><div class="card-body"><h2>{x}</h2><a href="https://wa.me/6280000000000">Tanya lokasi →</a></div></article>)}</div></div></section>
  : staticType==="tentang-meatfish" ? <section class="section"><div class="container"><header class="page-head"><h1>Tentang Meat & Fish</h1></header><div class="article-content"><p>Meat & Fish menyediakan daging, ayam, ikan, seafood, dan frozen food berkualitas untuk kebutuhan keluarga dan pelaku bisnis.</p><h2>Pasokan yang dapat diandalkan</h2><p>Kami mengembangkan jaringan toko, supplier, dan mitra untuk memperluas akses produk protein yang praktis dan berkualitas.</p></div></div></section>
  : staticType==="trend-daging-ikan-frozen" ? <section class="section"><div class="container"><header class="page-head"><h1>Trend Daging & Ikan Frozen</h1></header><div class="grid">{posts.map((p:any)=><article class="card"><img src={p.frontmatter.image||"/images/article-placeholder.svg"} alt={p.frontmatter.title}/><div class="card-body"><h2><a href={`/${p.frontmatter.slug}/`}>{p.frontmatter.title}</a></h2><p>{p.frontmatter.description}</p></div></article>)}</div></div></section>
  : <section class="section"><div class="container"><header class="page-head"><span class="pill">Meat & Fish</span><h1>{title}</h1><p class="lead">{description}</p></header><div class="article-layout"><article class="article-content"><img src={pageImage} alt={title}/><p>Halaman ini disiapkan berdasarkan struktur URL resmi Meat & Fish. Konten lengkap sedang ditinjau sebelum dipublikasikan.</p><h2>Produk berkualitas untuk kebutuhan Anda</h2><p>Temukan pilihan daging, ayam, ikan, seafood, dan makanan beku untuk kebutuhan keluarga maupun bisnis kuliner.</p><a class="button" href="/produk-meatfish/">Lihat Produk</a></article><aside class="sidebar"><h2>Jelajahi</h2><a href="/produk-meatfish/">Produk</a><a href="/daftar-supplier-meatfish/">Supplier</a><a href="/gabung-kemitraan/">Kemitraan</a></aside></div></div></section>}
</BaseLayout>

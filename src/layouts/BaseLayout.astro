---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
const {
  title = "Meat & Fish – Daging, Ikan & Frozen Food",
  description = "Pusat daging, ikan, seafood, dan frozen food berkualitas untuk keluarga dan bisnis.",
  image = "/wp-content/uploads/2025/10/ChatGPT-Image-Oct-12-2025-12_04_31-PM.png",
  type = "website"
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const organization = {
  "@context": "https://schema.org", "@type": "Organization", name: "Meat & Fish",
  url: "https://meatfish.co.id", logo: new URL("/wp-content/uploads/2025/10/mf-logo.webp", Astro.site).href
};
---
<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" /><meta name="viewport" content="width=device-width" />
    <title>{title}</title><meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content={type} /><meta property="og:title" content={title} />
    <meta property="og:description" content={description} /><meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(image, Astro.site)} />
    <meta name="twitter:card" content="summary_large_image" />
    <script type="application/ld+json" set:html={JSON.stringify(organization)} />
  </head>
  <body><Header /><main><slot /></main><Footer /><a class="floating-wa" href="https://wa.link/89ffhn" target="_blank" aria-label="Chat WhatsApp" rel="nofollow noopener"><img src="/images/WhatsApp_icon.png" alt="" /></a></body>
</html>
